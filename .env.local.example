# Database (Neon PostgreSQL)
# Get from: https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth (JWT Secret — generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-here

# Storage (Uploadthing)
# Get from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your-uploadthing-token

# Realtime (Ably)
# Get from: https://ably.com/accounts → App → API Keys
ABLY_API_KEY=your-ably-api-key
NEXT_PUBLIC_ABLY_KEY=your-ably-public-key

# Email (Resend — for password recovery, contact form)
# RESEND_API_KEY=your-resend-api-key

# Analytics (optional — app works without)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_CLARITY_ID=
